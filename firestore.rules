rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "fordkv@gmail.com" && request.auth.token.email_verified == true));
    }

    // Visitor Counter Rules
    match /stats/global {
      // Allow anyone to read the visitor count
      allow read: if true;
      
      // Allow anyone to increment the visitor count
      // We ensure it's a simple increment and no other fields are tampered with
      allow update: if request.resource.data.visitorCount == resource.data.visitorCount + 1
                   && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitorCount']);
      
      // Allow initial creation
      allow create: if request.resource.data.visitorCount == 1
                   && request.resource.data.keys().hasAll(['visitorCount']);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
